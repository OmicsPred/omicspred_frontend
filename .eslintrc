{
  "extends": [
    "react-app"
  ],
  "settings": {
    "react": {
      "version": "detect"
    },
    "import/resolver": {
      "node": {
        "paths": [
          "src"
        ],
        "extensions": [
          ".js",
          ".jsx"
        ]
      }
    }
  },
  "rules": {
    "eqeqeq": "off", // === and !== rule,
    "react-hooks/exhaustive-deps": "off", // React Hook useEffect missing dependencies
    "array-callback-return": "off",       // map() expects a return value
    "react/jsx-no-target-blank": "off"    // Using target="_blank" without rel="noreferrer"
  }
}
